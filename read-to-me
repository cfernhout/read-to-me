#!/usr/bin/env bash
# read-to-me — Read text aloud using edge-tts and mpv
set -euo pipefail

EDGE_TTS="${EDGE_TTS_BIN:-edge-tts}"
VOICE="${VOICE:-en-US-AriaNeural}"
PIDFILE="/tmp/read-to-me.pid"
TMPFILE="/tmp/read-to-me.mp3"
SPEED="+0%"

stop_playback() {
    if [[ -f "$PIDFILE" ]]; then
        xargs kill 2>/dev/null < "$PIDFILE" || true
        rm -f "$PIDFILE" "$TMPFILE"
    fi
}

usage() {
    cat <<'EOF'
Usage: read-to-me [-s SPEED] [FILE]
       read-to-me --stop
       command | read-to-me [-s SPEED]

Options:
  -s SPEED   Speed multiplier (default: 1.0, e.g. 1.5 = 50% faster)
  --stop     Stop current playback

Markdown files (.md) are automatically cleaned for natural speech.
EOF
    exit 0
}

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

if [[ "${1:-}" == "--stop" ]]; then
    stop_playback
    exit 0
fi

if [[ "${1:-}" == "-s" ]]; then
    SPEED=$(awk "BEGIN { pct = ($2 - 1) * 100; printf \"%+d%%\", pct }")
    shift 2
fi

# Kill previous playback
stop_playback

# Read from file or stdin
if [[ -n "${1:-}" && -f "$1" ]]; then
    INPUT=$(cat "$1")
else
    INPUT=$(cat)
fi

# Strip markdown formatting for natural speech
if [[ "${1:-}" == *.md ]]; then
    TEXT=$(echo "$INPUT" | sed \
        -e '/^---$/,/^---$/d'          \
        -e '/^```/,/^```/d'            \
        -e '/^|/d'                     \
        -e 's/^#\+ //'                \
        -e 's/\*\*\([^*]*\)\*\*/\1/g' \
        -e 's/\*\([^*]*\)\*/\1/g'     \
        -e 's/`[^`]*`//g'             \
        -e 's/\[\([^]]*\)\]([^)]*/\1/g' \
        -e 's/^- //'                   \
        -e 's/^[0-9]\+\. //'          \
        -e '/^[[:space:]]*$/d'         \
    )
else
    TEXT="$INPUT"
fi

if [[ -z "$TEXT" ]]; then
    echo "No text to speak" >&2
    exit 1
fi

# Generate audio, then play
echo "$TEXT" | "$EDGE_TTS" --voice "$VOICE" --rate="$SPEED" -f - --write-media "$TMPFILE" 2>/dev/null

mpv --no-video --really-quiet "$TMPFILE" &
echo $! > "$PIDFILE"

wait $! 2>/dev/null || true
rm -f "$PIDFILE" "$TMPFILE"
